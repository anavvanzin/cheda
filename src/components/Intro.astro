---
/**
 * CHÊDA — site intro overlay.
 *
 * A single self-contained 7-second film (1280×720) whose wordmark,
 * red/black treatment, silhouette and hypnosis are all baked in. We
 * simply present it, uncropped (object-fit:contain) on true black, and
 * dissolve into the landing when it ends. No competing overlay layers.
 *
 * Rendered server-side (no client framework, no hydration). Behaviour
 * lives in /scripts/intro.js loaded is:inline as a classic IIFE.
 */
---
<div id="intro" class="intro" role="dialog" aria-modal="true" aria-label="Abertura — Patrícia Chêda">
  <!-- The film. Muted + playsinline; started via play() from intro.js so
       returning-session and reduced-motion visitors never auto-download the
       clip. preload="metadata" keeps the first paint cheap (the poster is a
       representative frame from this exact file). Plays once (no loop). -->
  <video
    class="intro__media"
    poster="/assets/intro/intro-poster.jpg"
    muted
    playsinline
    preload="metadata"
    aria-hidden="true"
  >
    <source src="/assets/intro/intro.mp4" type="video/mp4" />
  </video>

  <!-- Discreet skip, tucked in the corner so it never covers the art -->
  <button type="button" class="intro__skip" aria-label="Pular abertura">Pular ›</button>

  <!-- Autoplay-fallback control: revealed by JS only if play() is blocked.
       Uses the same poster as its backdrop (the video underneath). -->
  <div class="intro__fallback" hidden>
    <button type="button" class="intro__enter" aria-label="Entrar no site">
      <span class="intro__enter-icon" aria-hidden="true">▶</span>
      Entrar
    </button>
  </div>
</div>

<!-- Re-open affordance, revealed only after the intro has been dismissed -->
<button type="button" id="intro-reopen" class="intro-reopen" hidden aria-label="Reabrir a abertura">↺ Abertura</button>
