---
import { siteContent } from '../data/site';

const soundcloudEmbedUrl = `https://w.soundcloud.com/player/?url=${encodeURIComponent(siteContent.contact.soundcloudUrl)}&color=%23B5221A&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false&visual=true`;
const genreLabel = siteContent.editorial.genres
  .map((genre) => genre.replace(/\b\w/g, (character) => character.toUpperCase()))
  .join(' · ');
const posterTags = ['DJ', genreLabel, siteContent.location.displayShort].join(' · ');
---

<!-- Custom cursor layers — hidden on touch/coarse via cursor.css -->
<div class="cursor-layer cursor-ring" id="cursor-ring" aria-hidden="true"></div>
<div class="cursor-layer cursor-disc" id="cursor-disc" aria-hidden="true"></div>
<div class="cursor-layer cursor-dot"  id="cursor-dot"  aria-hidden="true"></div>

<nav class="switcher" aria-label="Layouts">
  <a href="/print/ritual">3a</a>
  <a href="/print/poster">3b</a>
  <a href="/print/morph">morph</a>
  <a class="on" href="/" aria-current="page">spread</a>
</nav>
<div class="grain" aria-hidden="true"></div>

<!-- Atmospheric silhouette: the artist fades in from the bottom-right as
     a subtle ambient layer. Fixed, non-interactive, fully contained. -->
<div class="site-silhouette" aria-hidden="true">
  <img src="/assets/silhouette-cheda.webp" alt="" width="1080" height="1350"
       loading="lazy" decoding="async" />
</div>

<main class="spread">
  <h1 class="sr-only">{siteContent.site.defaultTitle}</h1>

  <!-- HERO — hollow, interlocking wordmark (the whole first screen) -->
  <section class="ritual" aria-label={siteContent.identity.stageName}>
    <div class="r-header will-reveal will-reveal-delay-1">
      <span class="kicker">Digital Press Kit · 2026</span>
    </div>

    <div class="r-title will-reveal will-reveal-delay-2">
      <span class="r-name">{siteContent.identity.stageName}</span>
      <span class="r-sub">
        <em class="r-serif">{siteContent.identity.artistName}</em>
        <span class="r-tagline">{siteContent.editorial.tagline}</span>
      </span>
    </div>
  </section>

  <!-- ARTIST — portrait now lives in its own section, below the hero -->
  <section class="artist" aria-label={siteContent.identity.artistName}>
    <div class="artist-portrait will-reveal">
      <img src="/assets/portrait-ritual.jpg"
           alt={`${siteContent.identity.artistName} — retrato editorial`}
           width="1080" height="1080" loading="lazy" decoding="async">
    </div>
    <div class="artist-copy will-reveal will-reveal-delay-1">
      <span class="kicker">DJ · {siteContent.location.displayShort}</span>
      <em class="artist-name">{siteContent.identity.artistName}</em>
      <p>{siteContent.editorial.officialShortBio}</p>
      <a class="booking-link" href={`${siteContent.contact.bookingMailto}?subject=Booking%20·%20Chêda`}>booking · {siteContent.contact.bookingEmail}</a>
    </div>
  </section>

  <!-- EDITORIAL — press photo gallery (swipeable on phones) -->
  <section class="editorial" aria-label="Editorial">
    <div class="editorial-head will-reveal">
      <span class="kicker">Editorial · Press</span>
    </div>
    <div class="editorial-grid">
      <figure class="ed-shot will-reveal">
        <img src="/assets/foto-editorial.jpg" alt={`${siteContent.identity.artistName} — editorial`}
             width="1080" height="1440" loading="lazy" decoding="async">
      </figure>
      <figure class="ed-shot will-reveal will-reveal-delay-1">
        <img src="/assets/foto-lattice.jpg" alt={`${siteContent.identity.artistName} — gradil`}
             width="1080" height="1440" loading="lazy" decoding="async">
      </figure>
      <figure class="ed-shot will-reveal will-reveal-delay-2">
        <img src="/assets/foto-steps.jpg" alt={`${siteContent.identity.artistName} — escadaria`}
             width="1080" height="1440" loading="lazy" decoding="async">
      </figure>
    </div>
  </section>

  <!-- VHS TRACKING SEAM -->
  <section class="seam" aria-label="Ritual → Poster tracking transition">
    <div class="seam-kicker will-reveal">▶ play · vhs · 3a → 3b · tracking</div>

    <div class="wobble-band wb-1" aria-hidden="true"></div>
    <div class="wobble-band wb-2" aria-hidden="true"></div>
    <div class="wobble-band wb-3" aria-hidden="true"></div>

    <div class="dropout d1" aria-hidden="true"></div>
    <div class="dropout d2" aria-hidden="true"></div>
    <div class="dropout d3" aria-hidden="true"></div>

    <div class="seam-word will-reveal will-reveal-delay-1" aria-hidden="true">
      <span class="word" data-word="CHÊDA">CHÊDA</span>
    </div>

    <div class="head-hash" aria-hidden="true"></div>

    <div class="seam-kicker bottom will-reveal will-reveal-delay-2">rec · sp · 00:03:42 · tracking</div>
  </section>

  <!-- 3b POSTER + SOUNDCLOUD SLOT -->
  <section class="poster" aria-label="3b Poster">
    <!-- LEFT column: content card + SoundCloud, single flow -->
    <div class="poster-left">
      <div class="content-card will-reveal">
        <div class="poster-logo">
          {siteContent.identity.stageName}
          <em class="poster-serif">{siteContent.identity.artistName}</em>
        </div>
        <div class="poster-tags">{posterTags}</div>
        <div class="card-divider"></div>
        <div class="bio-text">
          <p>{siteContent.editorial.officialShortBio}</p>
        </div>
      </div>

      <div class="sc-slot will-reveal will-reveal-delay-2" id="soundcloud">
        <div class="sc-meta">
          <span>SoundCloud · Featured Set</span>
          <span class="listen">▶ Listen</span>
        </div>
        <!-- Decorative live-analysis readout — a warm re-skin of the reference
             "AUDIO ANALYSIS / LIVE" equalizer. It visualizes nothing real, so the
             whole band is aria-hidden; the genuine listen affordance stays the
             untouched "▶ Listen" above and the SoundCloud iframe below. -->
        <div class="sc-analysis" aria-hidden="true">
          <div class="wf-cap">
            <span>Audio Analysis</span>
            <span class="wf-live"><i class="wf-live-dot"></i>Live</span>
          </div>
          <div class="wf">
            {Array.from({ length: 40 }).map(() => <i class="wf-bar"></i>)}
          </div>
        </div>
        <div class="sc-frame" id="sc-frame">
          <iframe scrolling="no" frameborder="no" allow="autoplay"
            title="Chêda — SoundCloud"
            src={soundcloudEmbedUrl}></iframe>
        </div>
      </div>
    </div>

    <!-- RIGHT column: type wall decoration -->
    <div class="poster-right">
      <div class="type-wall will-reveal will-reveal-delay-1" aria-hidden="true">
        <div class="tw-row"><span class="tw-word">CHÊDA</span></div>
        <div class="tw-row"><span class="tw-word">CHÊDA</span></div>
        <div class="tw-row"><span class="tw-word">CHÊDA</span></div>
        <div class="tw-row"><span class="tw-word">CHÊDA</span></div>
        <div class="tw-row"><span class="tw-word">CHÊDA</span></div>
        <div class="tw-row"><span class="tw-word">CHÊDA</span></div>
      </div>
    </div>
  </section>

</main>

<!-- ═══ SITE FOOTER (blackletter signature) ═══ -->
<footer class="site-footer will-reveal will-reveal-delay-3">
  <div class="foot-info">
    <span>Booking · <a href={`${siteContent.contact.bookingMailto}?subject=Booking%20·%20Chêda`}>{siteContent.contact.bookingEmail}</a></span>
    <span>Instagram · <a href={siteContent.contact.instagramUrl} target="_blank" rel="noopener">{siteContent.contact.instagramHandle}</a></span>
    <a class="sr-only sr-only-focusable" href={siteContent.contact.soundcloudUrl}>SoundCloud · {siteContent.identity.artistName}</a>
    <span>{siteContent.location.displayPt} · 2026</span>
  </div>
  <div class="foot-signature">
    <img src="/assets/logo-patricia-blackletter-black.png"
         alt={siteContent.identity.artistName}
         width="993" height="224">
  </div>
</footer>
