---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  withCursor?: boolean;
}
const {
  title = 'CHÊDA · Patrícia Chêda',
  description = 'DJ e selectora — techno, tech house, noise. Florianópolis, Brasil.',
  ogImage = 'https://patriciacheda.com/assets/favicon/og-image.jpg',
  withCursor = false,
} = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <link rel="icon" href="/assets/favicon/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon/icon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/favicon/icon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/icon-180.png" />
    <link rel="manifest" href="/assets/favicon/site.webmanifest" />
    <meta name="theme-color" content="#0E0B0A" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="CHÊDA" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://patriciacheda.com/" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500;1,600&family=Hanken+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
