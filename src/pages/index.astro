---
import Base from '../layouts/Base.astro';
import Intro from '../components/Intro.astro';
import LandingBody from '../components/LandingBody.astro';
import { assetVersion } from '../lib/asset-version';
import '../styles/tokens.css';
import '../styles/cursor.css';
import '../styles/landing.css';
import '../styles/intro.css';

// Keep the preload href byte-identical to the poster the intro requests,
// so the hint warms the same cache entry instead of double-fetching.
const posterSrc = `/assets/intro/intro-poster.jpg?v=${assetVersion('assets/intro/intro-poster.jpg')}`;
---
<Base>
  <Fragment slot="head">
    <!-- Paint the intro backdrop (true black stage) immediately so there
         is no flash of the landing before intro.css / intro.js resolve. -->
    <style is:inline>
      #intro{position:fixed;inset:0;z-index:9000;background:#000;}
      #intro.is-gone{display:none;}
    </style>
    <link rel="preload" as="image" href={posterSrc} />
  </Fragment>

  <Intro />
  <LandingBody />

  <script is:inline src="/scripts/intro.js"></script>
  <script is:inline src="/scripts/cursor.js"></script>
  <script is:inline src="/scripts/ambient.js"></script>
  <script is:inline src="/scripts/reel.js"></script>
</Base>
