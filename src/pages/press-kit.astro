---
import Base from '../layouts/Base.astro';
import PressKitBody from '../components/PressKitBody.astro';
import { siteContent } from '../data/site';
import '../styles/press-kit.css';

const canonicalUrl = new URL(
  Astro.url.pathname.replace(/\.html$/, ''),
  Astro.site ?? siteContent.site.canonicalUrl,
).href;

const ldJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: siteContent.identity.artistName,
  alternateName: siteContent.identity.stageName,
  jobTitle: siteContent.identity.rolePt,
  email: siteContent.contact.bookingMailto,
  url: canonicalUrl,
  sameAs: [
    siteContent.contact.instagramUrl,
    siteContent.contact.soundcloudUrl,
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: siteContent.location.city,
    addressRegion: siteContent.location.state,
    addressCountry: siteContent.location.countryCode,
  },
  knowsAbout: siteContent.editorial.genres,
});
---
<Base
  title={siteContent.pressKit.title}
  description={siteContent.pressKit.description}
  socialDescription={siteContent.pressKit.socialDescription}
  ogImage={siteContent.pressKit.ogImage}
  ogImageWidth={siteContent.pressKit.ogImageWidth}
  ogImageHeight={siteContent.pressKit.ogImageHeight}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={ldJson} />
  </Fragment>
  <PressKitBody />
  <script is:inline src="/scripts/press-kit.js"></script>
</Base>
