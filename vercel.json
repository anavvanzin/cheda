{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/print/spread",      "destination": "/", "permanent": true },
    { "source": "/print/spread.html", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
